# Docker Compose environment template.
# Copy to `.env` (gitignored) at the REPO ROOT and override for your environment.
#
# IMPORTANT: Compose v2 loads `.env` from the current working directory (repo
# root), NOT from deploy/docker-compose/. Values here are interpolated into the
# compose YAML via ${VAR:-default}; the defaults keep out-of-the-box dev working.
#
# Service config follows the loader in internal/config/config.go:
# prefix `SPATIAL_`, `__` is the nested-key separator mapping to koanf's `.`.

# --- Postgres (base infra) ---
POSTGRES_USER=spatial
POSTGRES_PASSWORD=spatial
POSTGRES_DB=spatial

# --- Service config (SPATIAL_ prefix) ---
SPATIAL_POSTGRES__DSN=postgres://spatial:spatial@postgres:5432/spatial?sslmode=disable
SPATIAL_GATEWAY__JWT_SECRET=dev-secret-key-change-in-production

# --- Observability ---
GRAFANA_ADMIN_PASSWORD=admin
